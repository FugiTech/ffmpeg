diff --git a/libavcodec/libsvtav1.c b/libavcodec/libsvtav1.c
index c6a0ff90bc..6522d711ce 100644
--- a/libavcodec/libsvtav1.c
+++ b/libavcodec/libsvtav1.c
@@ -71,8 +71,55 @@ typedef struct SvtContext {
     int enc_mode;
     int crf;
     int qp;
+
+    struct {
+        int64_t pts;
+        int64_t duration;
+    } *frame_durations;
+    int nb_frame_durations;
+    unsigned frame_durations_size;
 } SvtContext;

+static int store_frame_duration(SvtContext *svt_enc, int64_t pts, int64_t duration)
+{
+    void *tmp;
+    size_t needed;
+
+    if (pts == AV_NOPTS_VALUE || duration < 0)
+        return 0;
+
+    needed = (size_t)(svt_enc->nb_frame_durations + 1) * sizeof(*svt_enc->frame_durations);
+    tmp = av_fast_realloc(svt_enc->frame_durations, &svt_enc->frame_durations_size, needed);
+    if (!tmp)
+        return AVERROR(ENOMEM);
+
+    svt_enc->frame_durations = tmp;
+    svt_enc->frame_durations[svt_enc->nb_frame_durations].pts = pts;
+    svt_enc->frame_durations[svt_enc->nb_frame_durations].duration = duration;
+    svt_enc->nb_frame_durations++;
+
+    return 0;
+}
+
+static int64_t consume_frame_duration(SvtContext *svt_enc, int64_t pts)
+{
+    int i;
+
+    if (pts == AV_NOPTS_VALUE)
+        return 0;
+
+    for (i = 0; i < svt_enc->nb_frame_durations; i++) {
+        if (svt_enc->frame_durations[i].pts == pts) {
+            int64_t duration = svt_enc->frame_durations[i].duration;
+            svt_enc->frame_durations[i] = svt_enc->frame_durations[svt_enc->nb_frame_durations - 1];
+            svt_enc->nb_frame_durations--;
+            return duration;
+        }
+    }
+
+    return 0;
+}
+
 static const struct {
     EbErrorType    eb_err;
     int            av_err;
@@ -238,7 +285,11 @@ static int config_enc_params(EbSvtAv1EncConfiguration *param,
     } else if (svt_enc->qp > 0) {
         param->qp                   = svt_enc->qp;
         param->rate_control_mode    = 0;
+#if SVT_AV1_CHECK_VERSION(4, 0, 0)
+        param->aq_mode              = 0;
+#else
         param->enable_adaptive_quantization = 0;
+#endif
     }

     desc = av_pix_fmt_desc_get(avctx->pix_fmt);
@@ -306,13 +357,9 @@ static int config_enc_params(EbSvtAv1EncConfiguration *param,
         param->force_key_frames = 1;
 #endif

-    if (avctx->framerate.num > 0 && avctx->framerate.den > 0) {
-        param->frame_rate_numerator   = avctx->framerate.num;
-        param->frame_rate_denominator = avctx->framerate.den;
-    } else {
-        param->frame_rate_numerator   = avctx->time_base.den;
-        param->frame_rate_denominator = avctx->time_base.num;
-    }
+    // Keep a fixed nominal rate to avoid SVT-AV1 failures on high input fps.
+    param->frame_rate_numerator   = 100;
+    param->frame_rate_denominator = 1;

     /* 2 = IDR, closed GOP, 1 = CRA, open GOP */
     param->intra_refresh_type = avctx->flags & AV_CODEC_FLAG_CLOSED_GOP ? 2 : 1;
@@ -521,6 +568,10 @@ static int eb_send_frame(AVCodecContext *avctx, const AVFrame *frame)
     headerPtr->p_app_private = NULL;
     headerPtr->pts           = frame->pts;

+    ret = store_frame_duration(svt_enc, frame->pts, frame->duration);
+    if (ret < 0)
+        return ret;
+
     switch (frame->pict_type) {
     case AV_PICTURE_TYPE_I:
         headerPtr->pic_type = EB_AV1_KEY_PICTURE;
@@ -636,6 +687,7 @@ static int eb_receive_packet(AVCodecContext *avctx, AVPacket *pkt)
     pkt->size = headerPtr->n_filled_len;
     pkt->pts  = headerPtr->pts;
     pkt->dts  = headerPtr->dts;
+    pkt->duration = consume_frame_duration(svt_enc, pkt->pts);

     switch (headerPtr->pic_type) {
     case EB_AV1_KEY_PICTURE:
@@ -682,6 +734,9 @@ static av_cold int eb_enc_close(AVCodecContext *avctx)
     }

     av_buffer_pool_uninit(&svt_enc->pool);
+    av_freep(&svt_enc->frame_durations);
+    svt_enc->nb_frame_durations = 0;
+    svt_enc->frame_durations_size = 0;
     av_frame_free(&svt_enc->frame);
     ff_dovi_ctx_unref(&svt_enc->dovi);

